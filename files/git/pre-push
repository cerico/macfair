#!/bin/bash
remote_url="$2"
allowlist="$HOME/.config/git/push-main-allowlist"

while read -r _ _ remote_ref _; do
  [[ "$remote_ref" == "refs/heads/main" ]] || continue
  [[ -f "$allowlist" ]] && grep -qFx "$remote_url" "$allowlist" && continue
  echo "Push to main on $1 ($remote_url) is blocked."
  exit 1
done
